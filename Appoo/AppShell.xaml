<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Appoo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Appoo.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="Black"
    Shell.ForegroundColor="{StaticResource PureWhite}"
    Shell.TitleColor="{StaticResource PureWhite}"
    Shell.TabBarBackgroundColor="{StaticResource DarkBlack}"
    Shell.TabBarForegroundColor="{StaticResource PureWhite}"
    Shell.TabBarUnselectedColor="{StaticResource GrayText}"
    Shell.TabBarTitleColor="{StaticResource PureWhite}">

    <TabBar>
        <ShellContent Title="Home" Icon="icon_home.png"
                      ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent Title="Map" Icon="icon_map.png"
                      ContentTemplate="{DataTemplate views:GaodeMapPage}" />
        <ShellContent Title="Camera" Icon="icon_camera.png"
                      ContentTemplate="{DataTemplate views:CameraPage}" />
        <ShellContent Title="Spots" Icon="icon_star.png"
                      ContentTemplate="{DataTemplate views:RecommendPage}" />
        <ShellContent Title="Me" Icon="icon_profile.png"
                      ContentTemplate="{DataTemplate views:ProfilePage}" />
    </TabBar>
</Shell>