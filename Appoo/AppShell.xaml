<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Appoo.Views"
       x:Class="Appoo.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.BackgroundColor="{StaticResource WineRed}"
       Shell.ForegroundColor="{StaticResource PureWhite}"
       Shell.TitleColor="{StaticResource PureWhite}">

    <TabBar>
        <ShellContent Title="首页" Icon="icon_home.png"
                      ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent Title="地图" Icon="icon_map.png"
                      ContentTemplate="{DataTemplate views:GaodeMapPage}" />
        <ShellContent Title="拍照识景" Icon="icon_camera.png"
                      ContentTemplate="{DataTemplate views:CameraPage}" />
        <ShellContent Title="推荐" Icon="icon_star.png"
                      ContentTemplate="{DataTemplate views:RecommendPage}" />
        <ShellContent Title="设置" Icon="icon_settings.png"
                      ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>