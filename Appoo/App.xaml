<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 酒红×黑白高级色 -->
            <Color x:Key="WineRed">#722F37</Color>
            <!-- 酒红主色 -->
            <Color x:Key="DarkBlack">#1A1A1A</Color>
            <!-- 深黑 -->
            <Color x:Key="SoftWhite">#F5F0F0</Color>
            <!-- 柔白背景 -->
            <Color x:Key="PureWhite">#FFFFFF</Color>
            <Color x:Key="GrayText">#6B6B6B</Color>
            <Color x:Key="AccentGold">#D4AF37</Color>
            <!-- 金色点缀 -->
        </ResourceDictionary>
    </Application.Resources>
</Application>