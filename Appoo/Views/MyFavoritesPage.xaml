<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.MyFavoritesPage"
             Title="My Favorites"
             BackgroundColor="{StaticResource SoftWhite}">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="My Favorites" FontSize="24" FontAttributes="Bold"
               TextColor="{StaticResource WineRed}" HorizontalOptions="Center"/>
        <Label Text="You have no favorites yet." HorizontalOptions="Center" TextColor="Gray"/>
    </VerticalStackLayout>
</ContentPage>