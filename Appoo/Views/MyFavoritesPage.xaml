<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.MyFavoritesPage"
             Title="Favorites"
             BackgroundImageSource="mebg.jpg">
	<VerticalStackLayout Padding="30" Spacing="30">
		<Label Text="My Favorites" FontSize="30" FontAttributes="Bold"
               TextColor="{StaticResource WineRed}" HorizontalOptions="Center"/>
		<Label x:Name="NoFavsLabel" Text="No favorites yet." HorizontalOptions="Center" TextColor="#1874CD" FontSize="18"/>
		<VerticalStackLayout x:Name="FavoritesStack" Spacing="5" BackgroundColor="#BFEFFF" />
		<Button Text="Clear All" BackgroundColor="Gray" TextColor="White" CornerRadius="8" Clicked="OnClearAll"/>
	</VerticalStackLayout>
</ContentPage>