<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.ProfilePage"
             Title="Me"
             BackgroundImageSource="mebg.jpg">   
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="⚙️" Clicked="OnSettingsClicked"  />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="27" Padding="27" VerticalOptions="Center">

            <!-- 圆形头像区域 -->
            <Grid HorizontalOptions="Center" Margin="0,-27,0,0">
                <Ellipse WidthRequest="120" HeightRequest="120"
                         Fill="#E0E0E0"
                         Stroke="Black"
                         StrokeThickness="5" />
                <Image x:Name="ProfileImage"
                       Source="autohead.jpg"
                       WidthRequest="100" HeightRequest="100"
                       Aspect="AspectFill"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Image.Clip>
                        <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50" />
                    </Image.Clip>
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvatarTapped" />
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="📷" FontSize="20" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,8,8" />
            </Grid>

            <!-- 用户名 -->
            <Label x:Name="UsernameLabel"
                   Text="Not logged in"
                   FontSize="22" FontAttributes="Bold" 
                   TextColor="{StaticResource DarkBlack}"
                   HorizontalOptions="Center" />

            <!-- 中间按钮预留区 -->
            <Button Text="My Reviews" 
                    BackgroundColor="#8B2323" 
                    TextColor="White" CornerRadius="21" FontSize="17" FontAttributes="Bold"
                    HeightRequest="50"
                    Clicked="OnMyReviewsClicked" />

            <!-- My Favorites -->
            <Button Text="My Favorites"
                    BackgroundColor="#8B2323" TextColor="White" FontSize="17"
                    CornerRadius="21" Clicked="OnMyFavoritesClicked"
                    HeightRequest="50"
                    FontAttributes="Bold" />

            <!-- Login / Logout -->
            <Button x:Name="AuthButton"
                    Text="Login"
                    BackgroundColor="Gray" TextColor="#C0E0F8" FontSize="20" FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="21" Clicked="OnAuthButtonClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>