<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.RegisterPage"
             Title="Register"
             BackgroundColor="{StaticResource SoftWhite}">
	<VerticalStackLayout VerticalOptions="Center" Spacing="20" Padding="30">
		<Label Text="Register" FontSize="28" FontAttributes="Bold"
               TextColor="{StaticResource WineRed}" HorizontalOptions="Center"/>
		<Entry x:Name="UsernameEntry" Placeholder="Username"/>
		<Entry x:Name="NicknameEntry" Placeholder="Nickname"/>
		<Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True"/>
		<Button Text="Register" BackgroundColor="{StaticResource WineRed}" TextColor="White"
                CornerRadius="10" Clicked="OnRegisterClicked"/>
	</VerticalStackLayout>
</ContentPage>