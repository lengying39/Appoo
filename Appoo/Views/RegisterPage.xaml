<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.RegisterPage"
             Title="Register"
             BackgroundColor="{StaticResource SoftWhite}">
    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Label Text="Register" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource WineRed}" HorizontalOptions="Center"/>
        <Entry Placeholder="Username" />
        <Entry Placeholder="Nickname" />
        <Entry Placeholder="Password" IsPassword="True" />
        <Button Text="Register" BackgroundColor="{StaticResource WineRed}" TextColor="White" CornerRadius="10"/>
    </VerticalStackLayout>
</ContentPage>