<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.WriteReviewPage"
             Title="Write Reviews"
             BackgroundImageSource="note.jpg">
    <ScrollView>
        <VerticalStackLayout Spacing="9" Padding="62">
            <Label x:Name="SpotNameLabel" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource WineRed}"/>
            <Label Text="Evaluation content" FontAttributes="Bold"/>
            <Editor x:Name="ReviewEditor" HeightRequest="150" Placeholder="Share your experience..." AutoSize="TextChanges"/>

            <Label Text="Upload image (optional)" FontAttributes="Bold"/>
            <Button Text="📷 Select Image" Clicked="OnAttachPhoto" BackgroundColor="Gray" TextColor="White"/>
            <Image x:Name="SelectedImage" HeightRequest="120" Aspect="AspectFill" Margin="0,5,0,0"/>

            <Switch x:Name="ImageToggle" IsToggled="True"/>
            <Label Text="Includes images" />

            <Button Text="🙌🏻 Post Review" Clicked="OnSubmitClicked" BackgroundColor="#8b2323" TextColor="White" CornerRadius="10"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>