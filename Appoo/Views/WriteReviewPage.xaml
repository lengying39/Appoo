<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.WriteReviewPage"
             Title="Write Reviews"
             BackgroundImageSource="note.jpg">
    <ScrollView>
        <VerticalStackLayout Spacing="9" Padding="62">
            <Label x:Name="SpotNameLabel" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource WineRed}" />
            <Label Text="Evaluation content" FontAttributes="Bold" FontSize="18" TextColor="#3A79C0"/>
            <Editor x:Name="ReviewEditor" HeightRequest="120" Placeholder="Share your experience..." AutoSize="TextChanges" TextColor="Black" FontSize="16"/>

            <Label Text="Upload image (optional)" FontAttributes="Bold" TextColor="#3A79C0"/>
            <Button Text="📷 Select Image" Clicked="OnAttachPhoto" BackgroundColor="Gray" TextColor="Black" FontSize="20"/>
            <Image x:Name="SelectedImage" HeightRequest="220" Aspect="AspectFill" Margin="0,5,0,0"/>

            <Switch x:Name="ImageToggle" IsToggled="True"/>
            <Label Text="Includes images" TextColor="#3A79C0" Margin="0,-36,0,0"/>

            <Button Text="🙌🏻    Post Review" FontSize="20" Clicked="OnSubmitClicked" BackgroundColor="#8b2323" TextColor="White" CornerRadius="10" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>