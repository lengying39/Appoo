<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.HomePage"
             Title="首页"
             BackgroundColor="{StaticResource LightBg}">
	<ScrollView>
		<VerticalStackLayout Spacing="20" Padding="25">
			<!-- 顶部欢迎横幅 -->
			<Frame CornerRadius="15" BackgroundColor="{StaticResource Primary}" Padding="20" HasShadow="True">
				<VerticalStackLayout Spacing="5">
					<Label Text="🌍 旅行指南" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Accent}" HorizontalOptions="Center"/>
					<Label Text="探索身边的精彩" FontSize="16" TextColor="{StaticResource Accent}" HorizontalOptions="Center" Opacity="0.9"/>
				</VerticalStackLayout>
			</Frame>

			<!-- 获取位置卡片 -->
			<Frame CornerRadius="12" BackgroundColor="White" Padding="20" HasShadow="True">
				<VerticalStackLayout Spacing="10">
					<Label Text="📍 我的位置" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource DarkText}"/>
					<Label x:Name="LocationLabel" Text="点击下方按钮获取" FontSize="16" TextColor="Gray"/>
					<Button Text="获取当前位置"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="White"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnGetLocationClicked" />
				</VerticalStackLayout>
			</Frame>

			<!-- 附近景点推荐卡片 -->
			<Frame CornerRadius="12" BackgroundColor="White" Padding="20" HasShadow="True">
				<VerticalStackLayout Spacing="8">
					<Label Text="🏞️ 离你最近的景点" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource DarkText}"/>
					<Label x:Name="NearbyLabel" Text="计算中..." FontSize="16" TextColor="Gray"/>
				</VerticalStackLayout>
			</Frame>

			<Label Text="— 开启你的探索之旅 —" FontSize="14" HorizontalOptions="Center" TextColor="Gray" Margin="0,10,0,0"/>
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>