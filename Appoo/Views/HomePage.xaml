<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.HomePage"
             Title="Home"
             BackgroundImageSource="a.jpg">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="25">

            <!-- 欢迎横幅 -->
            <Border StrokeShape="RoundRectangle 15" BackgroundColor="#80FFFFFF"
                    Stroke="Transparent" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.3"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="5">
                    <Label Text="🌍 Travel Guide" FontSize="28" FontAttributes="Bold"
                           TextColor="{StaticResource PureWhite}" HorizontalOptions="Center"/>
                    <Label Text="Explore the beauty around you" FontSize="16"
                           TextColor="{StaticResource PureWhite}" HorizontalOptions="Center" Opacity="0.9"/>
                </VerticalStackLayout>
            </Border>

            <!-- 椭圆半透明搜索栏 -->
            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="WhiteSmoke"
                    Stroke="{StaticResource PureWhite}"
                    StrokeThickness="1.5"
                    Opacity="0.85"
                    Padding="12,0">
                <Entry x:Name="SearchEntry"
                       Placeholder="Search spots, food..."
                       PlaceholderColor="{StaticResource GrayText}"
                       TextColor="Black"
                       BackgroundColor="Transparent"
                       FontSize="16"
                       ClearButtonVisibility="WhileEditing"
                       TextChanged="OnSearchTextChanged" />
            </Border>

            <!-- ★ 搜索结果容器（初始隐藏） -->
            <Border x:Name="ResultsContainer"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource PureWhite}"
                    Stroke="Black"
                    StrokeThickness="1"
                    Padding="10"
                    IsVisible="False"
                    Margin="0,-10,0,0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                </Border.Shadow>
                <VerticalStackLayout x:Name="ResultsStack" Spacing="5" />
            </Border>

            <!-- My Location 卡片（增加上边距） -->
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#80FFFFFF"
                    Stroke="Transparent" Padding="20" Margin="0,50,0,0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="📍 My Location" FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource DarkBlack}"/>
                    <Label x:Name="LocationLabel" Text="Click button to get" FontSize="16"
                           TextColor="{StaticResource GrayText}"/>
                    <Button Text="Get Location" BackgroundColor="{StaticResource WineRed}"
                            TextColor="{StaticResource PureWhite}" CornerRadius="8" FontAttributes="Bold"
                            Clicked="OnGetLocationClicked"/>
                </VerticalStackLayout>
            </Border>

            <!-- Nearest Spot 卡片（增加上边距） -->
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#80FFFFFF"
                    Stroke="Transparent" Padding="20" Margin="0,10,0,0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="🏞️ Nearest Spot" FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource DarkBlack}"/>
                    <Label x:Name="NearbyLabel" Text="Calculating..." FontSize="16"
                           TextColor="{StaticResource GrayText}"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>