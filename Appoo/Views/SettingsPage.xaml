<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App00.Views.SettingsPage"
             Title="设置">
    <VerticalStackLayout Spacing="15" Padding="20">
        <Label Text="应用设置" FontSize="24" HorizontalOptions="Center"/>
        <Label Text="当前识别服务: 无法识别模式" x:Name="ModeLabel"/>
        <Label Text="切换需修改 MauiProgram.cs 中的服务注册" FontSize="12" TextColor="Gray"/>
        <Button Text="关于" Clicked="OnAboutClicked" />
    </VerticalStackLayout>
</ContentPage>