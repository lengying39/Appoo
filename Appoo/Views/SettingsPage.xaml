<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.SettingsPage"
             Title="设置"
             BackgroundColor="{StaticResource LightBg}">
    <VerticalStackLayout Spacing="20" Padding="25">
        <Frame CornerRadius="15" BackgroundColor="{StaticResource Primary}" Padding="20" HasShadow="True">
            <Label Text="⚙️ 应用设置" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
        </Frame>

        <Frame CornerRadius="12" BackgroundColor="White" Padding="20" HasShadow="True">
            <VerticalStackLayout Spacing="10">
                <Label Text="当前识别模式" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource DarkText}"/>
                <Label x:Name="ModeLabel" Text="离线模式（无法识别景点）" FontSize="15" TextColor="Gray"/>
                <Label Text="如需切换至 Azure 云端识别，请修改 MauiProgram.cs" FontSize="12" TextColor="LightGray"/>
            </VerticalStackLayout>
        </Frame>

        <Button Text="📖 关于"
                BackgroundColor="{StaticResource Secondary}"
                TextColor="White"
                CornerRadius="10"
                FontSize="17"
                HeightRequest="50"
                Clicked="OnAboutClicked" />

        <Label Text="旅行指南 v1.0" FontSize="14" TextColor="Gray" HorizontalOptions="Center" Margin="0,20,0,0"/>
    </VerticalStackLayout>
</ContentPage>