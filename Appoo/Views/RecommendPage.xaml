<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.RecommendPage"
             Title="推荐景点"
             BackgroundColor="{StaticResource LightBg}">
	<ScrollView>
		<VerticalStackLayout Spacing="15" Padding="20">
			<Label Text="⭐ 热门推荐" FontSize="26" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" HorizontalOptions="Center"
                   Margin="0,0,0,10"/>

			<!-- 大雁塔 -->
			<Frame CornerRadius="15" BackgroundColor="White" Padding="15" HasShadow="True">
				<VerticalStackLayout Spacing="8">
					<Image Source="spot_dayanta.jpg" Aspect="AspectFill" HeightRequest="180" />
					<Label Text="大雁塔" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource DarkText}"/>
					<Label Text="唐代古塔，大慈恩寺内，西安标志性建筑之一。" FontSize="14" TextColor="Gray"/>
				</VerticalStackLayout>
			</Frame>

			<!-- 钟楼 -->
			<Frame CornerRadius="15" BackgroundColor="White" Padding="15" HasShadow="True">
				<VerticalStackLayout Spacing="8">
					<Image Source="spot_zhonglou.jpg" Aspect="AspectFill" HeightRequest="180" />
					<Label Text="钟楼" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource DarkText}"/>
					<Label Text="西安市中心地标，建于明代，宏伟壮观。" FontSize="14" TextColor="Gray"/>
				</VerticalStackLayout>
			</Frame>

			<!-- 兵马俑 -->
			<Frame CornerRadius="15" BackgroundColor="White" Padding="15" HasShadow="True">
				<VerticalStackLayout Spacing="8">
					<Image Source="spot_bingmayong.jpg" Aspect="AspectFill" HeightRequest="180" />
					<Label Text="兵马俑" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource DarkText}"/>
					<Label Text="世界第八大奇迹，秦始皇陵陪葬坑。" FontSize="14" TextColor="Gray"/>
				</VerticalStackLayout>
			</Frame>

			<!-- 华清宫 -->
			<Frame CornerRadius="15" BackgroundColor="White" Padding="15" HasShadow="True">
				<VerticalStackLayout Spacing="8">
					<Image Source="spot_huaqinggong.jpg" Aspect="AspectFill" HeightRequest="180" />
					<Label Text="华清宫" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource DarkText}"/>
					<Label Text="唐代皇家温泉行宫，杨贵妃故事发生地。" FontSize="14" TextColor="Gray"/>
				</VerticalStackLayout>
			</Frame>
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>