<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.RecommendPage"
             Title="Recommended attractions"
             BackgroundImageSource="b.jpg">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="25">
            <Label Text="⭐ Gewilde besienswaardighede" FontSize="26" FontAttributes="Bold"
                   TextColor="Silver" HorizontalOptions="Center"/>

            <!-- 卡片列表使用 Bindings 或 静态数据，这里我们直接在 code-behind 中动态生成 -->
            <VerticalStackLayout x:Name="SpotList" Spacing="21"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>