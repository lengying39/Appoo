<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.LoginPage"
             Title="Login"
             BackgroundColor="{StaticResource SoftWhite}">
    <VerticalStackLayout VerticalOptions="Center" Spacing="20" Padding="30">
        <Label Text="Login" FontSize="28" FontAttributes="Bold"
               TextColor="{StaticResource WineRed}" HorizontalOptions="Center"/>
        <Entry x:Name="UsernameEntry" Placeholder="Username"/>
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True"/>
        <Button Text="Login" BackgroundColor="{StaticResource WineRed}" TextColor="White"
                CornerRadius="10" Clicked="OnLoginClicked"/>
        <Button Text="Register" BackgroundColor="Transparent" TextColor="{StaticResource WineRed}"
                Clicked="OnRegisterClicked"/>
    </VerticalStackLayout>
</ContentPage>