<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.LoginPage"
             Title="Login"
             BackgroundImageSource="bg8.jpg">
    <VerticalStackLayout VerticalOptions="Center" Spacing="25" Padding="36">
        <Label Text="Login" FontSize="39" FontAttributes="Bold"
               TextColor="Black"  HorizontalOptions="Center"/>
        <Entry x:Name="UsernameEntry" Placeholder="Username" FontSize="20"/>
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" FontSize="20"/>
        <Button Text="Login" BackgroundColor="White"  TextColor="Black" FontSize="18"
                CornerRadius="20" Clicked="OnLoginClicked"/>
        <Button Text="Register" BackgroundColor="Transparent" TextColor="Black"
                Clicked="OnRegisterClicked"/>

        <!-- 跳过按钮 -->
        <Button Text="Skip for now" BackgroundColor="Transparent" TextColor="Black"
                FontSize="15" Clicked="OnSkipClicked"/>

    </VerticalStackLayout>
</ContentPage>