<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="{StaticResource SoftWhite}">
	<VerticalStackLayout Spacing="20" Padding="25">
		<Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource WineRed}"
                Stroke="Transparent" Padding="20">
			<Border.Shadow>
				<Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.3"/>
			</Border.Shadow>
			<Label Text="⚙️ Settings" FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource PureWhite}" HorizontalOptions="Center"/>
		</Border>

		<Button Text="Switch to Azure Recognition (Need Config)" BackgroundColor="{StaticResource WineRed}"
                TextColor="{StaticResource PureWhite}" CornerRadius="8" Clicked="OnSwitchRecog"/>
		<Button Text="🗑️ Clear Cache" BackgroundColor="Gray" TextColor="White" CornerRadius="8" Clicked="OnClearCache"/>
		<Button Text="ℹ️ About" BackgroundColor="{StaticResource WineRed}" TextColor="White" CornerRadius="8" Clicked="OnAbout"/>
		<Label Text="Travel Guide v1.0" FontSize="14" TextColor="{StaticResource GrayText}" HorizontalOptions="Center" Margin="0,20,0,0"/>
	</VerticalStackLayout>
</ContentPage>