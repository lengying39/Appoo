<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.CameraPage"
             Title="拍照识景"
             BackgroundColor="{StaticResource SoftWhite}">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="25">
            <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource WineRed}"
                    Stroke="Transparent" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.3"/>
                </Border.Shadow>
                <Label Text="📷 拍摄景点" FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource PureWhite}" HorizontalOptions="Center"/>
            </Border>

            <Button Text="打开相机拍摄" BackgroundColor="{StaticResource WineRed}"
                    TextColor="{StaticResource PureWhite}" CornerRadius="12"
                    FontSize="18" HeightRequest="55" Clicked="OnTakePhotoClicked"/>

            <!-- 预览图 -->
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource PureWhite}"
                    Stroke="Transparent" Padding="10" x:Name="PreviewFrame" IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                </Border.Shadow>
                <Image x:Name="CapturedImage" Aspect="AspectFill" HeightRequest="250"/>
            </Border>

            <!-- 识别结果 -->
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource PureWhite}"
                    Stroke="Transparent" Padding="15" x:Name="ResultFrame" IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="🔍 识别结果" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource WineRed}"/>
                    <Label x:Name="ResultLabel" FontSize="16" TextColor="{StaticResource DarkBlack}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>