<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.CameraPage"
             Title="Camera"
             BackgroundImageSource="bg2.jpg">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="25">
            <Border StrokeShape="RoundRectangle 15" BackgroundColor="#79CDCD"
                    Stroke="Transparent" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.3"/>
                </Border.Shadow>
                <Label Text="📷 Take Photo" FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource PureWhite}" HorizontalOptions="Center"/>
            </Border>

            <!-- 拍照按钮 -->
            <Button Text="Capture"
                    BackgroundColor="#8B0000"
                    TextColor="{StaticResource PureWhite}" CornerRadius="12"
                    FontSize="18" HeightRequest="55"
                    Clicked="OnTakePhotoClicked"/>

            <!-- 从相册选择按钮 -->
            <Button Text="Select from Album"
                    BackgroundColor="#363636"
                    TextColor="{StaticResource PureWhite}" CornerRadius="12"
                    FontSize="18" HeightRequest="55"
                    Clicked="OnPickFromAlbumClicked"/>

            <!-- 预览图 -->
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource PureWhite}"
                    Stroke="Transparent" Padding="10" x:Name="PreviewFrame" IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                </Border.Shadow>
                <Image x:Name="CapturedImage" Aspect="AspectFill" HeightRequest="250"/>
            </Border>

            <!-- 识别结果 -->
            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource PureWhite}"
                    Stroke="Transparent" Padding="15" x:Name="ResultFrame" IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="🔍 Result" FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource WineRed}"/>
                    <Label x:Name="ResultLabel" FontSize="16" TextColor="{StaticResource DarkBlack}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>