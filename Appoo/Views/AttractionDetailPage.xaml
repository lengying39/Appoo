<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.AttractionDetailPage"
             Title="Attraction Detail"
             BackgroundColor="{StaticResource SoftWhite}">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label x:Name="NameLabel" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource DarkBlack}"/>
        <Label x:Name="DescLabel" FontSize="16" TextColor="White"/>
        <Label x:Name="OpenLabel" FontSize="14" TextColor="{StaticResource GrayText}"/>
        <Label x:Name="LocationLabel" FontSize="14" TextColor="{StaticResource GrayText}"/>
        <Button x:Name="FavoriteButton" Text="Add to Favorites" BackgroundColor="{StaticResource WineRed}" TextColor="White" CornerRadius="8"/>
    </VerticalStackLayout>
</ContentPage>