<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.AttractionDetailPage"
             Title="Attraction Details"
             BackgroundImageSource="detailbg.jpg">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <!-- 景点名称 -->
            <Label x:Name="NameLabel" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource DarkBlack}"
                   HorizontalOptions="Center"
                   Margin="0,10,0,5"/>

            <!-- 开放时间 -->
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <Label Text="🕒" FontSize="18" VerticalOptions="Center" Margin="0,10,0,0" />
                <Label x:Name="OpenLabel" Grid.Column="1" FontSize="18" TextColor="Black" Margin="0,10,0,0"/>

                <Label Text="📌" Grid.Row="1" FontSize="18" VerticalOptions="Center" Margin="0,12,0,10"/>
                <Label x:Name="LocationLabel" Grid.Row="1" Grid.Column="1" FontSize="18" TextColor="Black" Margin="0,12,0,10"/>
            </Grid>

            <!-- 详细描述（英文） -->
            <Border BackgroundColor="#E0FFFFFF"
                    StrokeShape="RoundRectangle 12"
                    Padding="15"
                    Margin="0,5">
                <Label x:Name="DescLabel" 
                       FontSize="16" 
                       TextColor="{StaticResource DarkBlack}"
                       LineBreakMode="WordWrap"/>
            </Border>

            <!-- 收藏按钮 -->
            <Button x:Name="FavoriteButton"
                    Text="💗   Add to MyFavorite"
                    BackgroundColor="#C0E0F8"
                    TextColor="#d45959" FontSize="18"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Margin="0,80,0,0"
                    Clicked="OnFavoriteButtonClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>