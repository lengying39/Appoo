<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Appoo.Converters"
             x:Class="Appoo.Views.FoodPage"
             Title="Nearby Food"
             BackgroundImageSource="msbg2.jpg">

    <ContentPage.Resources>
        <converters:FavoriteStarConverter x:Key="FavoriteStarConverter"/>
    </ContentPage.Resources>

    <CollectionView x:Name="FoodCollectionView" ItemsSource="{Binding FoodItems}" 
                    RemainingItemsThreshold="5">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#bf202020" Stroke="Transparent"
                        Padding="20" Margin="12,9">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                    </Border.Shadow>
                    <!-- 列定义：图片列(120)，文字列(*)，按钮列(Auto) -->
                    <Grid ColumnDefinitions="120,*,Auto">
                        <!-- 图片 -->
                        <Image Source="{Binding ImageFileName}" 
                               HeightRequest="130" WidthRequest="120" 
                               Aspect="AspectFill" 
                               Grid.RowSpan="2" 
                               Margin="0,-10,0,-10" />
                        <!-- 文字信息 -->
                        <VerticalStackLayout Grid.Column="1" Margin="20,5,0,0">
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="{Binding Description}" FontSize="12" TextColor="#D8DEF7"/>
                            <Label Text="{Binding Price}" FontSize="14" TextColor="#FF6" Margin="0,8,0,-1"/>
                        </VerticalStackLayout>
                        <!-- 收藏按钮（右上角） -->
                        <Button x:Name="FavoriteButton" 
                                Text="{Binding IsFavorite, Converter={StaticResource FavoriteStarConverter}}"
                                BackgroundColor="Transparent"
                                TextColor="Gold"
                                FontSize="24"
                                WidthRequest="50" HeightRequest="50"
                                HorizontalOptions="End" 
                                VerticalOptions="Start"
                                Command="{Binding ToggleFavoriteCommand}"
                                Grid.Column="2" 
                                Grid.RowSpan="2" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>