<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.FoodPage"
             Title="附近美食"
             BackgroundColor="{StaticResource SoftWhite}">
    <CollectionView x:Name="FoodCollectionView" ItemsSource="{Binding FoodItems}" 
                    RemainingItemsThreshold="5">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border StrokeShape="RoundRectangle 15" BackgroundColor="#80FFFFFF" Stroke="Transparent"
                        Padding="10" Margin="10,5">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="100,*">
                        <!-- 图片位置：留空，你需要自己上传图片时替换 Source -->
                        <Image Source="placeholder_food.png" HeightRequest="80" WidthRequest="80" Aspect="AspectFill" Grid.RowSpan="2" Margin="5"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource DarkBlack}"/>
                            <Label Text="{Binding Description}" FontSize="12" TextColor="{StaticResource GrayText}"/>
                            <Label Text="{Binding Price}" FontSize="12" TextColor="{StaticResource WineRed}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>