<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.FoodPage"
             Title="Nearby Food"
             BackgroundImageSource="msbg.jpg">
    <CollectionView x:Name="FoodCollectionView" ItemsSource="{Binding FoodItems}" 
                    RemainingItemsThreshold="5">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border StrokeShape="RoundRectangle 18" BackgroundColor="#bf202020" Stroke="Transparent"
                        Padding="25" Margin="12,8">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="2,4" Radius="6" Opacity="0.2"/>
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="100,*">
                        <!-- 图片位置：留空，你需要自己上传图片时替换 Source -->
                        <Image Source="{Binding ImageFileName}" HeightRequest="80" WidthRequest="80" Aspect="AspectFill" Grid.RowSpan="2" Margin="5"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0">
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="{Binding Description}" FontSize="15" TextColor="#D8DEF7"/>
                            <Label Text="{Binding Price}" FontSize="14" TextColor="#FF6"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>