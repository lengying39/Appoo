<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.SearchPage"
             Title="Search"
             BackgroundColor="{StaticResource SoftWhite}">
	<VerticalStackLayout Padding="20" Spacing="10">
		<Label Text="Search" FontSize="24" FontAttributes="Bold"
               TextColor="{StaticResource WineRed}" HorizontalOptions="Center"/>
		<Entry x:Name="SearchEntry" Placeholder="Search attractions, food, facilities..." TextChanged="OnSearchTextChanged"/>
		<VerticalStackLayout x:Name="ResultsStack" Spacing="5"/>
	</VerticalStackLayout>
</ContentPage>