<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.TestimonialOptionsPage"
             Title="用户评价"
             BackgroundColor="{StaticResource SoftWhite}">
    <VerticalStackLayout Spacing="30" Padding="30" VerticalOptions="Center">
        <Label Text="你想做什么？" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Button Text="✍️ 写评价" Clicked="OnWriteReviewClicked" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="15" HeightRequest="60"/>
        <Button Text="👀 查看评价" Clicked="OnViewReviewsClicked" BackgroundColor="#2196F3" TextColor="White" CornerRadius="15" HeightRequest="60"/>
    </VerticalStackLayout>
</ContentPage>