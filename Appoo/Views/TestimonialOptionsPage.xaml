<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Appoo.Views.TestimonialOptionsPage"
             Title="User Review"
             BackgroundImageSource="userreviewbg.jpg">
    <VerticalStackLayout Spacing="30" Padding="30" VerticalOptions="Center">
        <Label Text="What do you want？" FontSize="30" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Button Text="✍️ Write My Review" Clicked="OnWriteReviewClicked" BackgroundColor="#00B2EE"  TextColor="White" CornerRadius="15" HeightRequest="60"/>
        <Button Text="👀 View other people's reviews" Clicked="OnViewReviewsClicked" BackgroundColor="MediumPurple"  TextColor="White" CornerRadius="15" HeightRequest="60"/>
    </VerticalStackLayout>
</ContentPage>