<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assignment.Pages.FoodPage"
             Title="Nearby Food">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="🍜 Nearby Food" FontSize="24" FontAttributes="Bold"/>

            <Frame BackgroundColor="White" Padding="16" CornerRadius="15">
                <VerticalStackLayout>
                    <Label Text="Biángbiáng Noodles" FontSize="18" FontAttributes="Bold"/>
                    <Label Text="100m away · Local specialty"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" Padding="16" CornerRadius="15">
                <VerticalStackLayout>
                    <Label Text="Roujiamo" FontSize="18" FontAttributes="Bold"/>
                    <Label Text="150m away · Traditional snack"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>