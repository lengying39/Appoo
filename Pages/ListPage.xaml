<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assignment.Pages.ListPage"
             Title="Attractions">

    <ScrollView Padding="15">
        <VerticalStackLayout Spacing="15">

            <SearchBar Placeholder="Search attractions..."
                       HorizontalOptions="FillAndExpand"/>

            <Button Text="Emperor Qinshihuang's Mausoleum Site Museum"
                    BackgroundColor="#FF6F00"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="GoToDetail1"/>

            <Button Text="Dayan Pagoda"
                    BackgroundColor="#FF6F00"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="GoToDetail2"/>

            <Button Text="The Xi'an Circumvallation"
                    BackgroundColor="#FF6F00"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="GoToDetail3"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>