<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assignment.Pages.ListPage"
             BackgroundColor="#F2F2F2"
             Title="景点列表">
    <VerticalStackLayout Padding="20" Spacing="14">

        <Frame CornerRadius="14" BackgroundColor="White" Padding="16">
            <VerticalStackLayout>
                <Label Text="兵马俑" FontSize="18" FontAttributes="Bold"/>
                <Label Text="500米 | 收费景点"/>
                <Button Text="查看详情"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        Clicked="GoToBingMaYong"/>
            </VerticalStackLayout>
        </Frame>

        <Frame CornerRadius="14" BackgroundColor="White" Padding="16">
            <VerticalStackLayout>
                <Label Text="大雁塔" FontSize="18" FontAttributes="Bold"/>
                <Label Text="800米 | 收费景点"/>
                <Button Text="查看详情"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        Clicked="GoToDaYanTa"/>
            </VerticalStackLayout>
        </Frame>

        <Frame CornerRadius="14" BackgroundColor="White" Padding="16">
            <VerticalStackLayout>
                <Label Text="西安城墙" FontSize="18" FontAttributes="Bold"/>
                <Label Text="2公里 | 收费景点"/>
                <Button Text="查看详情"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        Clicked="GoToXiAnChengQiang"/>
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>