<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assignment.MainPage"
             BackgroundColor="#F8F9FC">
    <ScrollView>
        <VerticalStackLayout Margin="28" Spacing="24">

            <HorizontalStackLayout HorizontalOptions="Fill" Margin="0,0,0,10">
                <Label Text="Tourist Navigator"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="#1A237E"
                       HorizontalOptions="StartAndExpand"/>
                <Button Text="🔍"
                        BackgroundColor="#3949AB"
                        TextColor="White"
                        CornerRadius="18"
                        WidthRequest="44"
                        HeightRequest="44"
                        Clicked="GoToSearchPage"/>
                <Button Text="📷"
                        BackgroundColor="#FF6F00"
                        TextColor="White"
                        CornerRadius="18"
                        WidthRequest="44"
                        HeightRequest="44"
                        Margin="8,0,0,0"/>
            </HorizontalStackLayout>

            <Label Text="Explore the world with smart navigation"
                   FontSize="16"
                   TextColor="#5F6368"
                   HorizontalOptions="Start"/>

            <Frame BackgroundColor="White" Padding="20" CornerRadius="20">
                <VerticalStackLayout Spacing="4">
                    <Label Text="📍 Current Location" 
                           FontSize="14" 
                           TextColor="#78909C"/>
                    <Label Text="Xi'an, China" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#1A237E"/>
                    <Label Text="GPS connected · Service Hotline: 84586666" 
                           FontSize="12" 
                           TextColor="#5F6368"/>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Spacing="16">
                <Button Text="🗺️ Nearby Attractions"
                        BackgroundColor="#3949AB"
                        TextColor="White"
                        CornerRadius="22"
                        HeightRequest="72"
                        FontSize="18"
                        FontAttributes="Bold"
                        Clicked="GoToListPage"/>

                <Button Text="🍜 Nearby Food"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="22"
                        HeightRequest="72"
                        FontSize="18"
                        FontAttributes="Bold"
                        Clicked="GoToFoodPage"/>

                <Button Text="🏛️ Public Facilities"
                        BackgroundColor="#9C27B0"
                        TextColor="White"
                        CornerRadius="22"
                        HeightRequest="72"
                        FontSize="18"
                        FontAttributes="Bold"
                        Clicked="GoToFacilitiesPage"/>

                <Button Text="⭐ My Favorites"
                        BackgroundColor="#FF6F00"
                        TextColor="White"
                        CornerRadius="22"
                        HeightRequest="72"
                        FontSize="18"
                        FontAttributes="Bold"
                        Clicked="GoToFavoritePage"/>
            </VerticalStackLayout>

            <Label Text="🔥 Recommended Places" 
                   FontAttributes="Bold" 
                   FontSize="22"
                   TextColor="#1A237E"
                   Margin="0,10,0,0"/>

            <Frame BackgroundColor="White" Padding="20" CornerRadius="20">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Emperor Qinshihuang's Mausoleum Site Museum" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#1A237E"/>
                    <Label Text="500m away · Open now" 
                           FontSize="14" 
                           TextColor="#5F6368"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" Padding="20" CornerRadius="20">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Dayan Pagoda" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#1A237E"/>
                    <Label Text="800m away · Open now" 
                           FontSize="14" 
                           TextColor="#5F6368"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>