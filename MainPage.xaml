<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assignment.MainPage"
             Background="#F8F9FC">

    <Grid RowDefinitions="*, Auto">

        <!-- 主内容滚动区 -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Margin="32" Spacing="28">

                <!-- 标题 + 功能按钮 -->
                <HorizontalStackLayout HorizontalOptions="Fill" Margin="0,0,0,12">
                    <Label Text="Tourist Navigator"
                           FontSize="36"
                           FontAttributes="Bold"
                           TextColor="#1A237E"
                           HorizontalOptions="StartAndExpand"/>

                    <Button Text="🔍"
                            BackgroundColor="#3949AB"
                            TextColor="White"
                            CornerRadius="22"
                            WidthRequest="48"
                            HeightRequest="48"
                            Margin="0,0,6,0"
                            Clicked="GoToSearchPage"/>

                    <Button Text="📷"
                            BackgroundColor="#FF6F00"
                            TextColor="White"
                            CornerRadius="22"
                            WidthRequest="48"
                            HeightRequest="48"/>
                </HorizontalStackLayout>

                <!-- 副标题 -->
                <Label Text="Explore the world with smart navigation"
                       FontSize="17"
                       TextColor="#5F6368"
                       Opacity="0.85"/>

                <!-- 当前位置卡片（悬浮质感） -->
                <Frame BackgroundColor="White"
                       Padding="36"
                       CornerRadius="30">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📍 Current Location" 
                               FontSize="15" 
                               TextColor="#78909C"/>
                        <Label Text="Xi'an, China" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#1A237E"/>
                        <Label Text="GPS connected · Service Hotline: 84586666" 
                               FontSize="13" 
                               TextColor="#5F6368"
                               Opacity="0.8"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- 推荐标题 -->
                <Label Text="🔥 Recommended Places" 
                       FontAttributes="Bold" 
                       FontSize="24"
                       TextColor="#1A237E"
                       Margin="0,14,0,6"/>

                <!-- 推荐景点 1 -->
                <Frame BackgroundColor="White"
                       Padding="24"
                       CornerRadius="24">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Emperor Qinshihuang's Mausoleum Site Museum" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="#1A237E"/>
                        <Label Text="500m away · Open now" 
                               FontSize="15" 
                               TextColor="#5F6368"
                               Opacity="0.85"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- 推荐景点 2 -->
                <Frame BackgroundColor="White"
                       Padding="24"
                       CornerRadius="24">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Dayan Pagoda" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="#1A237E"/>
                        <Label Text="800m away · Open now" 
                               FontSize="15" 
                               TextColor="#5F6368"
                               Opacity="0.85"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 底部导航栏（质感升级 + 无报错版） -->
        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="8"
              HeightRequest="70">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 景点 -->
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                <Button Text="🗺️"
                        BackgroundColor="Transparent"
                        TextColor="#3949AB"
                        FontSize="24"
                        WidthRequest="56"
                        HeightRequest="40"
                        Clicked="GoToListPage"/>
                <Label Text="Attractions" FontSize="11" TextColor="#3949AB" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- 美食 -->
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                <Button Text="🍜"
                        BackgroundColor="Transparent"
                        TextColor="#4CAF50"
                        FontSize="24"
                        WidthRequest="56"
                        HeightRequest="40"
                        Clicked="GoToFoodPage"/>
                <Label Text="Food" FontSize="11" TextColor="#4CAF50" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- 设施 -->
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                <Button Text="🏛️"
                        BackgroundColor="Transparent"
                        TextColor="#9C27B0"
                        FontSize="24"
                        WidthRequest="56"
                        HeightRequest="40"
                        Clicked="GoToFacilitiesPage"/>
                <Label Text="Facilities" FontSize="11" TextColor="#9C27B0" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- 收藏 -->
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                <Button Text="⭐"
                        BackgroundColor="Transparent"
                        TextColor="#FF6F00"
                        FontSize="24"
                        WidthRequest="56"
                        HeightRequest="40"
                        Clicked="GoToFavoritePage"/>
                <Label Text="Favorites" FontSize="11" TextColor="#FF6F00" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>